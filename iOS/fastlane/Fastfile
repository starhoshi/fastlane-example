fastlane_version "2.19.2"

default_platform :ios

import_from_git(
  url: 'https://github.com/classi/fastlane-example',
  path: 'Util/Fastfile'
)

private_lane :reset_build do
  # build_id 更新などで差分が出る project.pbxproj と Info.plist を復元する
  sh('cd "$(git rev-parse --show-toplevel)" && git ls-files | grep -E "(project\\.pbxproj|Info\\.plist)$" | while read -r f; do git restore --staged --worktree -- "$f"; done; true')
end

private_lane :next_ios_build_number do |options|
  version = options[:version] || get_version_number
  base = Time.now.strftime("%Y%m%d0000").to_i

  begin
    latest = latest_testflight_build_number(
      api_key: options[:api_key],
      version: version,
      initial_build_number: base - 1
    )
    latest_i = latest.to_i
    (latest_i >= base ? latest_i + 1 : base).to_s
  rescue => error
    UI.user_error!("App Store Connect から build 番号取得に失敗したため終了します: #{error.message}")
  end
end

private_lane :upload_dsyms_to_crashlytics_if_configured do
  gsp_path = ENV['GOOGLE_SERVICES_INFO_PLIST_PATH'].to_s.strip

  if gsp_path.empty? || !File.exist?(gsp_path)
    UI.important("GOOGLE_SERVICES_INFO_PLIST_PATH が未設定、空文字、またはファイルが存在しないため Crashlytics への dSYM upload を skip します")
    next
  end

  upload_symbols_to_crashlytics(
    gsp_path: gsp_path,
    binary_path: './scripts/upload-symbols'
  )
end

platform :ios do
  changelog = ""
  default_payloads = [:lane, :test_result, :git_branch, :git_author]
  keychain = {name: "name", password: "password"}

  before_all do
    # ENV['DELIVER_ITMSTRANSPORTER_ADDITIONAL_UPLOAD_PARAMETERS'] = '-t DAV'

    changelog = changelog_from_git_commits_hs

    if is_ci?
   #   sh("rm /Users/distiller/Library/Keychains/#{keychain[:name]}-db || echo")
      
      setup_ci(
        force: true,
        provider: "travis",
      )

   #   create_keychain(
   #     name: keychain[:name],
   #     password: keychain[:password],
   #     default_keychain: true,
   #     unlock: true,
   #     timeout: 3600,
   #     lock_when_sleeps: false
   #   )
    end
  end


  desc "Runs all the tests"
  lane :test do
    scan
    xcov(
      workspace: ENV["XCOV_WORKSPACE"],
      scheme: ENV["XCOV_SCHEME"],
      exclude_targets: ENV["XCOV_EXCLUDE_TARGETS"]
    )
    danger
  end


  desc "Deploy a new version to the App Store"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'], 
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_KEY_CONTENT'],
    )
    
    # Download and install certificate
    if is_ci?
      match(type: "appstore", git_url: ENV["GITHUB_CERTIFICATES_REPO"])
    else
      match(type: "appstore")
    end

    # Update build number
    increment_build_number(
      build_number: next_ios_build_number(api_key: api_key)
    )

    # Compile
    gym(scheme: ENV["RELEASE_GYM_SCHEME"])

    # Save ipa and dSYM
    if is_ci?
      sh "cp #{lane_context[SharedValues::IPA_OUTPUT_PATH]} $CIRCLE_ARTIFACTS"
      sh "cp #{lane_context[SharedValues::DSYM_OUTPUT_PATH]} $CIRCLE_ARTIFACTS"
    end

    # Upload ipa to iTunes Connect
    deliver

    # Upload dSYM to crashslytics
    upload_dsyms_to_crashlytics_if_configured

    # Get diff from the last tag
    sh("git tag -d v#{get_version_number} || echo")
    diff = git_tag_diff

    # Create git tag
    # Force pushing because it may create the same tag more than once.
    add_git_tag(
      tag: "v#{get_version_number}",
      message: "build_number: #{get_build_number} by fastlane\n\n#{diff}",
      force: true
    )
    push_git_tags(force: true)

    # notify slack
    payload = {"Git Commit" => changelog}
    payload["Repo"] = ENV["GITHUB_REPOSITORY"] if ENV["GITHUB_REPOSITORY"]
    slack(
      channel: ENV["SLACK_CHANNEL"],
      message: ":itunesconnect: Successfully uploaded a new App Store build",
      payload: payload,
      default_payloads: default_payloads
    )
  end

  desc "Upload a new build to TestFlight only"
  lane :testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_KEY_CONTENT'],
    )

    # Download and install certificate
    if is_ci?
      match(type: "appstore", git_url: ENV["GITHUB_CERTIFICATES_REPO"])
    else
      match(type: "appstore")
    end

    # Update build number
    increment_build_number(
      build_number: next_ios_build_number(api_key: api_key)
    )

    # Compile
    gym(scheme: ENV["RELEASE_GYM_SCHEME"])

    # Save ipa and dSYM
    if is_ci?
      sh "cp #{lane_context[SharedValues::IPA_OUTPUT_PATH]} $CIRCLE_ARTIFACTS"
      sh "cp #{lane_context[SharedValues::DSYM_OUTPUT_PATH]} $CIRCLE_ARTIFACTS"
    end

    # Upload to TestFlight
    upload_to_testflight(api_key: api_key)

    # Upload dSYM to Crashlytics
    upload_dsyms_to_crashlytics_if_configured

    # notify slack
    payload = {"Git Commit" => changelog}
    payload["Repo"] = ENV["GITHUB_REPOSITORY"] if ENV["GITHUB_REPOSITORY"]
    slack(
      channel: ENV["SLACK_CHANNEL"],
      message: ":testflight: Successfully uploaded a new TestFlight build",
      payload: payload,
      default_payloads: default_payloads
    )
  end


  desc "Download dSYMs from iTunesConnect and upload to crashylitics"
  lane :refresh_dsyms do
    download_dsyms
    upload_symbols_to_crashlytics(
      gsp_path: ENV['GOOGLE_SERVICES_INFO_PLIST_PATH'],
      binary_path: './scripts/upload-symbols'
    )
    clean_build_artifacts

    payload = {}
    payload["Repo"] = ENV["GITHUB_REPOSITORY"] if ENV["GITHUB_REPOSITORY"]
    slack(
      message: "Successfully uploaded dSYMs to :crashlytics:",
      payload: payload
    )
  end


  desc "Update app_version and create release branch in GitHub"
  desc "ex: fastlane release_branch version:1.0.0"
  lane :release_branch do |options|
    # Check arguments
    UI.user_error!("Required release version. ex: fastlane release_branch version:1.0.0") unless options[:version]
    branch = "release/#{options[:version]}"

    # Create release branch
    sh("git checkout master && git pull origin master")
    sh("git checkout -b #{branch}")

    # Update version_number and git commit
    increment_version_number(version_number: options[:version])
    commit_version_bump(
      message: "Create #{branch} branch.",
      xcodeproj: ENV["XCODEPROJ"]
    )

    # Push to GitHub and create Pull Reqeust
    push_to_git_remote
    create_pull_request(
      repo: ENV["GITHUB_REPOSITORY"],
      title: "#{branch}",
      body: "release v#{options[:version]}"
    )
  end

  
  error do |lane, exception|
    # Reset iOS directory changes on error
    reset_build

    payload = {}
    payload["Repo"] = ENV["GITHUB_REPOSITORY"] if ENV["GITHUB_REPOSITORY"]
    slack(
      channel: ENV["SLACK_CHANNEL"],
      message: exception.message,
      success: false,
      payload: payload
    )
  end


  after_all do
    reset_build
  end
end
